    "platform": "Squarespace",
    "templateFamily": "Bedford/Anya (Squarespace 7.0)",
    "extractedAt": "2026-02-13",
    "screenshot": "/tmp/pixelstory-home.png"
  },

  "colors": {
    "primary": {
      "coral": "rgb(255, 87, 87)",
      "coralHex": "#FF5757",
      "teal": "rgb(82, 194, 200)",
      "tealHex": "#52C2C8",
      "black": "rgb(0, 0, 0)",
      "blackHex": "#000000",
      "white": "rgb(255, 255, 255)",
      "whiteHex": "#FFFFFF"
    },
    "neutral": {
      "darkGray": "rgb(13, 13, 13)",
      "darkGrayHex": "#0D0D0D",
      "mediumGray": "rgb(153, 153, 153)",
      "mediumGrayHex": "#999999",
      "lightGray": "rgb(221, 221, 221)",
      "lightGrayHex": "#DDDDDD",
      "nearBlack": "rgb(17, 17, 17)",
      "nearBlackHex": "#111111"
    },
    "backgrounds": {
      "body": "#FFFFFF",
      "header": "#52C2C8",
      "footer": "#0D0D0D",
      "cta": "#FF5757"
