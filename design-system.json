  "typography": {
    "fonts": {
      "heading": {
        "family": "dinosaur",
        "source": "Adobe Typekit (via use.typekit.net)",
        "fallback": "sans-serif",
        "weights": [300, 400, 700],
        "styles": ["normal", "italic"],
        "note": "Custom Adobe font. For Next.js, license through Adobe Fonts or substitute with a similar geometric sans-serif like 'Poppins' or 'Outfit'."
      },
      "body": {
        "family": "Libre Franklin",
        "source": "Google Fonts",
        "url": "https://fonts.googleapis.com/css2?family=Libre+Franklin:ital,wght@0,400;0,500;0,700;1,400;1,500;1,700",
        "weights": [400, 500, 700],
        "styles": ["normal", "italic"]
      },
      "accent": {
        "family": "Fjalla One",
        "source": "Google Fonts",
        "url": "https://fonts.googleapis.com/css2?family=Fjalla+One:wght@400",
        "weights": [400],
        "usage": "Section labels, button text, uppercase headings"
      }
    },
    "scale": {
      "h1": {
        "fontFamily": "dinosaur",
        "fontSize": "54px",
        "fontWeight": 400,
        "letterSpacing": "0.54px",
        "lineHeight": "normal",
        "color": "#000000"
      },
      "h2": {
        "fontFamily": "dinosaur",
        "fontSize": "32px",
        "fontWeight": 300,
        "letterSpacing": "0.64px",
        "lineHeight": "normal",
        "color": "#000000"
      },
      "h3": {
        "fontFamily": "Fjalla One",
        "fontSize": "13px",
        "fontWeight": 400,
        "letterSpacing": "normal",
        "textTransform": "uppercase",
        "color": "#000000",
        "usage": "Section subheadings / labels like 'Nice to E-Meet you'"
      },
      "body": {
        "fontFamily": "Libre Franklin",
        "fontSize": "12px",
        "fontWeight": 400,
        "letterSpacing": "0.72px",
        "lineHeight": "21.6px",
        "color": "#000000"
      },
      "navItem": {
        "fontFamily": "dinosaur",
        "fontSize": "14px",
        "fontWeight": 400,
        "letterSpacing": "0.84px",
        "textTransform": "uppercase",
        "color": "#999999"
      },
      "branding": {
        "fontFamily": "dinosaur",
        "fontSize": "64px",
        "fontWeight": 400,
        "letterSpacing": "2.56px",
        "textTransform": "uppercase",
        "color": "#FF5757"
      }
    }
  },

  "layout": {
    "maxWidth": "1680px",
    "siteWidth": "full-background",
    "headerInnerPadding": "15px 35px",
    "containerWidth": "1440px",
    "sections": [
      {
        "id": "home-projects-category",
        "name": "Top Project Category",
        "height": 2008,
        "bg": "#FFFFFF",
        "layout": "2x2 grid of project cards with images"
      },
      {
        "id": "home-credo",
        "name": "Hero / Credo",
        "height": 1024,
        "bg": "transparent (has background image)",
        "layout": "Split layout - image left, text content right",
        "note": "Parallax background image enabled"
      },
      {
        "id": "home-about",
        "name": "About Julika",
        "height": 829,
        "bg": "#FFFFFF",
        "layout": "Text content with heading and bio paragraph"
      }
    ]
  },

  "components": {
    "header": {
      "backgroundColor": "#52C2C8",
      "position": "static",
      "innerMaxWidth": "1680px",
      "innerPadding": "15px 35px",
      "display": "flex",
      "alignItems": "center",
      "note": "Header uses display:none at 1440px viewport (likely shows only on scroll or mobile). Branding and nav visible in alternate layout."
    },
    "navigation": {
      "structure": {
        "topLevel": ["Design X Life (folder)", "Projects (folder)", "Design Therapy", "Elevate", "About"],
        "designXLife": ["The Vision", "The PS Story Blog"],
        "projects": ["Company Culture & Wellbeing", "Community Building", "Diversity & Inclusion", "Good Design & Mental Health", "All Projects Portfolio"]
      },
      "desktop": {
        "fontFamily": "dinosaur",
        "fontSize": "14px",
        "fontWeight": 400,
        "letterSpacing": "0.84px",
        "textTransform": "uppercase",
        "color": "#999999",
        "hoverStyle": "plain"
      },
      "mobile": {
        "fontFamily": "Libre Franklin",
        "fontSize": "16px",
        "fontWeight": 500,
        "color": "#FFFFFF",
        "overlay": {
          "backgroundColor": "#52C2C8",
          "slideOrigin": "left"
        }
      }
    },
    "button": {
      "primary": {
        "backgroundColor": "#FF5757",
        "color": "#FFFFFF",
        "border": "none",
        "borderRadius": "0px",
        "padding": "21px 34px",
        "fontFamily": "Fjalla One",
        "fontSize": "15px",
        "fontWeight": 400,
        "letterSpacing": "1.5px",
        "textTransform": "uppercase",
        "shape": "square"
      },
      "style": "solid",
      "cornerStyle": "square"
    },
    "footer": {
      "backgroundColor": "#0D0D0D",
      "textColor": "#FFFFFF",
      "height": 857,
      "layout": "columns (auto)",
      "content": {
        "contactInfo": "Pixel Story Studio, Amsterdam, The Netherlands, info@pixelstorystudio.com",
        "instagramFeed": true,
        "socialIcons": "solid, square style"
      }
    },
    "projectCard": {
      "layout": "Image with text overlay/caption below",
      "readMoreLink": "Read More (arrow)",
      "imageAspect": "landscape"
    }
  },

